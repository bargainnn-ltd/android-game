rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    match /players/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.user_id == userId;
    }

    // Pairing transactions delete two tickets in one txn; a stricter rule needs Cloud Functions.
    match /matchmaking/{ticketId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid;
      allow delete: if signedIn();
    }

    match /matches/{matchId} {
      allow read: if signedIn()
        && request.auth.uid in resource.data.players;

      allow create: if signedIn()
        && request.auth.uid in request.resource.data.players
        && request.resource.data.players.size() == 2;

      allow update, delete: if signedIn()
        && request.auth.uid in resource.data.players;
    }

    match /matches/{matchId}/moves/{moveId} {
      allow read, write: if signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.players;
    }

    match /leaderboard_cache/{docId} {
      allow read: if signedIn();
      allow write: if false;
    }
  }
}
